---
layout: layouts/page
permalink: /blog/
eyebrow: arquivo
title: Blog
description: Todos os posts publicados até agora, em ordem cronológica.
eleventyComputed:
  meta: >
    {{ collections.posts.length }} post{% if collections.posts.length != 1 %}s{% endif %} publicado{% if collections.posts.length != 1 %}s{% endif %}.
eleventyNavigation:
  key: Blog
  order: 3
---

{% if collections.posts.length > 0 %}
    <ol class="post-timeline" role="list">
        {% for post in collections.posts %}
            {% set visibleTags = post.data.tags | filterTagList %}
            <li class="post-timeline__item">
                <article class="post-timeline__entry">
                    <time class="post-timeline__date" datetime="{{ post.date | htmlDateString }}">
                        {{ post.date | readableDate("dd 'de' LLL yyyy") }}
                    </time>

                    <h2 class="post-timeline__title">
                        <a href="{{ post.url }}#main">{{ post.data.title }}</a>
                    </h2>

                    {% if post.data.description %}
                        <p class="post-timeline__excerpt">{{ post.data.description }}</p>
                    {% endif %}

                    {% if visibleTags and visibleTags.length %}
                        <ul class="tag-list tag-list--muted" role="list" aria-label="Tags do post">
                            {% for tag in visibleTags %}
                                <li>{{ tag }}</li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </article>
            </li>
        {% endfor %}
    </ol>
{% else %}
    <p>Nenhum post encontrado.</p>
{% endif %}
