<!DOCTYPE html>
<html lang="pt-BR">
    <head>
        {% include "head.njk" %}
    </head>
    <body>
        <header class="sidebar">
            <a class="me" aria-label="Página inicial" href="/">
                <img width="144" height="144" src="https://gravatar.com/avatar/343a416fd183746c03fa7c2cd750cf15?size=256&cache=1729188961042" alt="Retrato de {{ site.title }}">
            </a>

            <div class="identity">
                <p class="title">
                    <a aria-label="Página inicial" href="/">{{ site.title }}</a>
                </p>
                <p class="desc">{{ site.desc }}</p>
            </div>

            <nav class="navigation" aria-label="Principal">
                {%- set navPages = collections.all | eleventyNavigation %}
                <ul role="list">
                    {% for entry in navPages %}
                        {%- set isActive = page.url == '/' if entry.url == '/' else page.url.indexOf(entry.url) == 0 -%}
                        <li class="{% if isActive %}is-active{% endif %}">
                            <a href="{{ entry.url }}"{% if isActive %} aria-current="page"{% endif %}>
                                {{ entry.title }}
                            </a>
                        </li>
                    {%- endfor %}
                </ul>
            </nav>

            <ul role="list" class="social-links">
                <li>
                    <a rel="me" href="https://fosstodon.org/@celio" aria-label="Mastodon">
                        {% icon "custom:mastodon-logo--duotone", width = "22px" %}
                    </a>
                </li>
            </ul>
        </header>
        <main id="main">
            {{ content | safe }}
        </main>
    </body>
</html>
