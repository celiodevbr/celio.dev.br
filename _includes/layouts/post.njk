---
layout: layouts/base
---

{% set visibleTags = tags | filterTagList %}

<section class="page page--post">
    <article class="post">
        <header class="page__header post__header">
            <p class="post__kicker">arquivo / post</p>
            <h1 class="page__title post__title">{{ title }}</h1>
            {% if description %}
                <p class="post__dek">{{ description }}</p>
            {% endif %}
            <div class="post__meta">
                <time class="post__date" datetime="{{ page.date | htmlDateString }}">
                    {% icon "custom:calendar-dot", width = "1.15em" %}
                    <span>{{ page.date | readableDate }}</span>
                </time>
                {% if visibleTags and visibleTags.length %}
                    <ul class="tag-list post__tags" role="list" aria-label="Tags do post">
                        {% for tag in visibleTags %}
                            <li class="tag-list__item">{{ tag }}</li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </header>
        <div class="page__content content post__content">
            {{ content | safe }}
        </div>
        {% if visibleTags and visibleTags.length %}
            <footer class="post__footer">
                <p class="post__footer-label">Indexado em</p>
                <ul class="tag-list tag-list--muted post__tags" role="list" aria-label="Tags do post no rodapé">
                    {% for tag in visibleTags %}
                        <li class="tag-list__item">{{ tag }}</li>
                    {% endfor %}
                </ul>
            </footer>
        {% endif %}
    </article>
</section>

