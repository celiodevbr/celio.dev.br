---
layout: layouts/base
---

<section class="page">
	<header>
		{% if eyebrow %}
			<p class="eyebrow">{{ eyebrow }}</p>
		{% endif %}

		<h1 class="title">{{ title }}</h1>

		{% if description %}
			<p class="intro">{{ description }}</p>
		{% endif %}

		{% if meta %}
			<div class="meta">
				<div class="infobox {{ tone or 'info' }}">
					<p>{{ meta | safe }}</p>
				</div>
			</div>
		{% endif %}
	</header>
	<div class="content">
		{{ content | safe }}
	</div>
</section>