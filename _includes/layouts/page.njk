---
layout: layouts/base
---

<section class="page">
    <header class="page__header">
        {% if eyebrow %}
            <p class="page__eyebrow">{{ eyebrow }}</p>
        {% endif %}

        <h1 class="page__title">{{ title }}</h1>

        {% if description %}
            <p class="page__intro">{{ description }}</p>
        {% endif %}

        {% if meta %}
            <div class="infobox infobox--{{ tone or 'info' }} page__meta">
                <p class="infobox__content">{{ meta | safe }}</p>
            </div>
        {% endif %}
    </header>
    <div class="page__content content">
        {{ content | safe }}
    </div>
</section>

